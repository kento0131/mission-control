# ============================================================
# Mission Control - 環境変数一覧
# ============================================================
# Vercel ダッシュボードで以下を設定すること
# ============================================================

# Convex production URL
NEXT_PUBLIC_CONVEX_URL=https://opulent-clam-873.convex.cloud

# HTTP API エンドポイント認証トークン
# 各エージェントが Authorization: Bearer <token> で送信する値
# Convex ダッシュボード > Settings > Environment Variables にも設定必要
OPENCLAW_SECRET=your-secret-token-here
